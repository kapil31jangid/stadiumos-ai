{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://stadiumos-ai-r7cq.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": { "service": "frontend" }
    }
  ]
}
