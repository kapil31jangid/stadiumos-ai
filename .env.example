# Supabase Connection Settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend Service Role Connection (Bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# PostgreSQL Direct Connection String (Connection pooling suggested)
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Gemini AI API Key
GOOGLE_API_KEY=your-gemini-api-key

# FastAPI Server Port
PORT=8080
HOST=0.0.0.0
