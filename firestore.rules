rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read-only access to specific collections
    match /zones/{zone} {
      allow read: if true;
      allow write: if false; // Only manageable via Admin SDK (backend)
    }
    match /queues/{queue} {
      allow read: if true;
      allow write: if false; // Only manageable via Admin SDK (backend)
    }
    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}